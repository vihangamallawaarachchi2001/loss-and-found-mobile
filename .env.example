# Use this for Expo Go testing from a physical device.
# Replace with your PC LAN IP where gateway is running on port 8080.
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8080
EXPO_PUBLIC_API_BASE_URL=http://<YOUR_PC_IP>:8080

# App environment: ui (mock), dev/prod (real API)
EXPO_PUBLIC_NATIVE_ENV=dev
